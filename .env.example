# PLAGENOR 4.0 — Configuration Environnement
# Copiez ce fichier en .env et ajustez les valeurs.

# Répertoire des données
PLAGENOR_DATA_DIR=./data

# Paramètres financiers
PLAGENOR_VAT_RATE=0.19
PLAGENOR_BUDGET_CAP=200000.0
PLAGENOR_INV_PREFIX=GENOCLAB-INV

# SLA (jours)
PLAGENOR_SLA_IBTIKAR=21
PLAGENOR_SLA_GENOCLAB=14

# Sécurité
PLAGENOR_SESSION_TIMEOUT=480
PLAGENOR_MAX_LOGIN=5
PLAGENOR_MAX_UPLOAD_MB=50

# Logging
PLAGENOR_LOG_LEVEL=INFO

# SMTP (notifications par email)
PLAGENOR_SMTP_HOST=
PLAGENOR_SMTP_PORT=587
PLAGENOR_SMTP_USER=
PLAGENOR_SMTP_PASSWORD=
PLAGENOR_SMTP_ENABLED=false
