# ============================================================
# PLAGENOR 4.0 — Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in the values before first run.
# Never commit .env to version control.
#
#   cp .env.example .env     (Linux/macOS)
#   copy .env.example .env   (Windows)
# ============================================================

# ── Database ──────────────────────────────────────────────────
# Directory where plagenor.db is stored (relative or absolute path)
PLAGENOR_DATA_DIR=./data

# ── Security ──────────────────────────────────────────────────
# Session timeout in minutes (default: 60)
PLAGENOR_SESSION_TIMEOUT=60

# Maximum consecutive failed login attempts before lockout
PLAGENOR_MAX_LOGIN=5

# Maximum file upload size in megabytes
PLAGENOR_MAX_UPLOAD_MB=50

# ── SMTP (optional — for email notifications) ─────────────────
# Set PLAGENOR_SMTP_ENABLED=true to activate email sending
PLAGENOR_SMTP_ENABLED=false
PLAGENOR_SMTP_HOST=smtp.gmail.com
PLAGENOR_SMTP_PORT=587
PLAGENOR_SMTP_USER=
PLAGENOR_SMTP_PASSWORD=
PLAGENOR_SMTP_FROM_NAME=PLAGENOR 4.0
PLAGENOR_SMTP_FROM_EMAIL=

# ── Financial ─────────────────────────────────────────────────
# VAT rate as a decimal (0.19 = 19%)
PLAGENOR_VAT_RATE=0.19

# Annual budget cap in DZD
PLAGENOR_BUDGET_CAP=200000.0

# Invoice number prefix
PLAGENOR_INV_PREFIX=GENOCLAB-INV

# SLA deadlines in days
PLAGENOR_SLA_IBTIKAR=21
PLAGENOR_SLA_GENOCLAB=14

# ── Logging ───────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
PLAGENOR_LOG_LEVEL=INFO
